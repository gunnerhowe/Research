\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Lorenz-96 main results: mean $\pm $ s.d.\ over confirmatory seeds (shared base checkpoint per seed; identical fine-tuning budgets). Bold = best among fine-tuned generative conditions. IET = inter-event time; RP = return period; TPP-LL = catalog-TPP log-likelihood of rollout events (ground-truth ceiling $-0.0994$); CRPS at lead 20 steps.}}{5}{table.1}\protected@file@percent }
\newlabel{tab:main}{{1}{5}{Lorenz-96 main results: mean $\pm $ s.d.\ over confirmatory seeds (shared base checkpoint per seed; identical fine-tuning budgets). Bold = best among fine-tuned generative conditions. IET = inter-event time; RP = return period; TPP-LL = catalog-TPP log-likelihood of rollout events (ground-truth ceiling $-0.0994$); CRPS at lead 20 steps}{table.1}{}}
\citation{jiang2023training}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Inter-event-time statistics, Lorenz-96 (pooled over 5 seeds). Left: IET densities; ground truth (shaded) is multimodal at wave-recurrence harmonics. Right: quantile--quantile against ground truth; TPP-aux (red) tracks the diagonal; the Poissonized prior (blue) severely distorts the distribution.}}{6}{figure.1}\protected@file@percent }
\newlabel{fig:iet}{{1}{6}{Inter-event-time statistics, Lorenz-96 (pooled over 5 seeds). Left: IET densities; ground truth (shaded) is multimodal at wave-recurrence harmonics. Right: quantile--quantile against ground truth; TPP-aux (red) tracks the diagonal; the Poissonized prior (blue) severely distorts the distribution}{figure.1}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.2}Kuramoto--Sivashinsky: the boundary of a timing-only prior}{6}{subsection.5.2}\protected@file@percent }
\newlabel{sec:ks}{{5.2}{6}{Kuramoto--Sivashinsky: the boundary of a timing-only prior}{subsection.5.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Conditional event hazard vs.\ time since the last event. Ground truth (black) oscillates at the recurrence period. The base surrogate over-amplifies the oscillation; TPP-aux (red) matches it; the rate-matched Poisson prior (blue) flattens it --- the content-specificity dissociation in a single curve.}}{7}{figure.2}\protected@file@percent }
\newlabel{fig:hazard}{{2}{7}{Conditional event hazard vs.\ time since the last event. Ground truth (black) oscillates at the recurrence period. The base surrogate over-amplifies the oscillation; TPP-aux (red) matches it; the rate-matched Poisson prior (blue) flattens it --- the content-specificity dissociation in a single curve}{figure.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Kuramoto--Sivashinsky results (3 seeds; $\dagger $: single exploratory seed). Ground-truth catalog-TPP ceiling: $-0.050$. The timing-only prior collapses the event rate; the rate-only (Poisson) prior --- harmful on Lorenz-96 --- is here the best return-period condition; increment statistics ($u_t$) repair the dynamics and most of the timing.}}{7}{table.2}\protected@file@percent }
\newlabel{tab:ks}{{2}{7}{Kuramoto--Sivashinsky results (3 seeds; $\dagger $: single exploratory seed). Ground-truth catalog-TPP ceiling: $-0.050$. The timing-only prior collapses the event rate; the rate-only (Poisson) prior --- harmful on Lorenz-96 --- is here the best return-period condition; increment statistics ($u_t$) repair the dynamics and most of the timing}{table.2}{}}
