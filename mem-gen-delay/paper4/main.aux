\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Public Pythia checkpoints (models we did not train).} The previous-token head (green) rises a full public-checkpoint stage before the induction-head score (blue) and the behavioral copy advantage (red) cliff together. Left: pythia-70m; right: pythia-160m. The 70m model also partially \emph  {loses} induction late in training (prefix 0.93$\to $0.36{} at 67B tokens) --- capability regression exists and is monitorable.}}{5}{figure.3}\protected@file@percent }
\newlabel{fig:pythia}{{3}{5}{\textbf {Public Pythia checkpoints (models we did not train).} The previous-token head (green) rises a full public-checkpoint stage before the induction-head score (blue) and the behavioral copy advantage (red) cliff together. Left: pythia-70m; right: pythia-160m. The 70m model also partially \emph {loses} induction late in training (prefix \wPyPrefixB $\to $\wPySeventyLatePrefix {} at 67B tokens) --- capability regression exists and is monitorable}{figure.3}{}}
